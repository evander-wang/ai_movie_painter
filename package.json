{
  "name": "short-flow-canvas-prototype",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b --noEmit",
    "test:unit": "vitest run tests/application",
    "test:golden": "vitest run tests/golden",
    "build": "tsc -b && vite build",
    "check:all": "npm run typecheck && npm run test:unit && npm run test:golden && npm run build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "@xyflow/react": "^12.10.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "smol-toml": "^1.7.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.1.10"
  }
}
